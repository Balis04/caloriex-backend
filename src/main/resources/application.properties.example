spring.application.name=caloriex-backend

spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}

# Local backend:
# DB_URL=jdbc:postgresql://localhost:5432/caloriex
# Docker backend:
# DB_URL=jdbc:postgresql://postgres:5432/caloriex
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.servlet.multipart.max-file-size=${APP_MULTIPART_MAX_FILE_SIZE:10MB}
spring.servlet.multipart.max-request-size=${APP_MULTIPART_MAX_REQUEST_SIZE:10MB}

logging.level.org.hibernate=warn

app.jwt.secret=${APP_JWT_SECRET:CHANGE_ME_TO_A_LONG_RANDOM_SECRET_CHANGE_ME}
app.jwt.expiration-minutes=10
spring.security.oauth2.resourceserver.jwt.issuer-uri=${AUTH0_ISSUER_URI:https://dev-s6p5lk76jv2ydpek.us.auth0.com/}
USDA_API_KEY=${USDA_API_KEY}
app.cors.allowed-origins=${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173}

spring.mail.host=${MAIL_HOST:}
spring.mail.port=${MAIL_PORT:587}
spring.mail.username=${MAIL_USERNAME:}
spring.mail.password=${MAIL_PASSWORD:}
spring.mail.properties.mail.smtp.auth=${MAIL_SMTP_AUTH:true}
spring.mail.properties.mail.smtp.starttls.enable=${MAIL_SMTP_STARTTLS_ENABLE:true}
app.mail.training-request.from=${TRAINING_REQUEST_MAIL_FROM:${MAIL_USERNAME:}}

app.storage.r2.access-mode=${APP_STORAGE_R2_ACCESS_MODE:PUBLIC}
# In PUBLIC mode configure a public base URL or a public bucket endpoint.
# PROTECTED mode is intentionally blocked until a dedicated authorized download flow exists.

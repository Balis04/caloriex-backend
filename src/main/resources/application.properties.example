spring.application.name=caloryx-backend

spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}

# Local backend:
# DB_URL=jdbc:postgresql://localhost:5432/caloryx
# Docker backend:
# DB_URL=jdbc:postgresql://postgres:5432/caloryx
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

logging.level.org.hibernate=warn

app.jwt.secret=${APP_JWT_SECRET:CHANGE_ME_TO_A_LONG_RANDOM_SECRET_CHANGE_ME}
app.jwt.expiration-minutes=10
spring.security.oauth2.resourceserver.jwt.issuer-uri=${AUTH0_ISSUER_URI:https://dev-s6p5lk76jv2ydpek.us.auth0.com/}
USDA_API_KEY=${USDA_API_KEY}
app.cors.allowed-origins=${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173}
